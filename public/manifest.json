{
  "manifest_version": 3,
  "name": "Snap Scroll",
  "version": "1.1.0",
  "description": "Mark a scroll checkpoint and snap back to it instantly.",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "webNavigation",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "css": ["content/style.css"]
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "commands": {
    "save_checkpoint": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S",
        "windows": "Alt+S",
        "linux": "Alt+S"
      },
      "description": "Save current scroll position"
    },
    "jump_checkpoint": {
      "suggested_key": {
        "default": "Alt+J",
        "mac": "Alt+J",
        "windows": "Alt+J",
        "linux": "Alt+J"
      },
      "description": "Jump to saved scroll position"
    },
    "delete_checkpoint": {
      "suggested_key": {
        "default": "Alt+X",
        "mac": "Alt+X",
        "windows": "Alt+X",
        "linux": "Alt+X"
      },
      "description": "Delete the saved scroll position"
    }
  }
}
